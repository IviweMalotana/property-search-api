<Project>
  <PropertyGroup>
    <WebPublishMethod>ZipDeploy</WebPublishMethod>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://property-search-api.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ProjectGuid>328dcf97-9548-159e-d528-f84d6161eede</ProjectGuid>
    <PublishUrl>https://property-search-api.scm.azurewebsites.net/</PublishUrl>
    <UserName>$property-search-api</UserName>
    <_SavePWD>true</_SavePWD>
  </PropertyGroup>
</Project>